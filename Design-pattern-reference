4. Observer / Event Bus — Handshake & Async Validation

Where it applies:
Validation handshake between distributed nodes

Purpose:
Decouple sender/receiver and avoid blocking flows.

Template:

class EventBus:
    def __init__(self):
        self.subscribers = {}
    def subscribe(self, event, handler):
        self.subscribers.setdefault(event, []).append(handler)
    def publish(self, event, data):
        for handler in self.subscribers.get(event, []):
            handler(data)
# Example usage
def on_validation_complete(data):
    print("Validation result:", data)
bus = EventBus()
bus.subscribe("validation_complete", on_validation_complete)
bus.publish("validation_complete", {"status": "ok"})

